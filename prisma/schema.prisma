// Prisma schema — 阶段2(创作者端 MVP:活动、报名、投稿)
// 后续阶段逐步加入 激励/爬虫/数据三层 等模型

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CREATOR
  OPERATOR
  ADMIN
}

enum ActivityStatus {
  DRAFT
  ONGOING
  ENDED
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

// 单项审核(标题/内容/易闪)结果
enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// 创作灵感:大类
enum InspirationType {
  VIDEO_TUTORIAL // 视频教程
  DOC_TUTORIAL // 文档教程
  MATERIAL // 创作素材
}

// 创作素材子分类(仅 type=MATERIAL 时使用,其他场景为 null)
enum MaterialCategory {
  VIDEO // 视频素材
  IMAGE // 图片素材
  TEXT_PROMPT // 文本素材 - 提示词
  TEXT_STORY // 文本素材 - 故事
  TEXT_OTHER // 文本素材 - 其他
}

// 爬虫机/Agent 状态
enum CrawlerAgentStatus {
  ACTIVE
  DISABLED
}

// 爬虫任务状态机:PENDING → RUNNING → SUCCEEDED/FAILED;CANCELED 是管理员手动终止。
// 重构后(2026-06 阶段4 改造):废抢占式,所有任务必定绑定一台 Agent,/claim 时直接 RUNNING。
enum CrawlerTaskStatus {
  PENDING // 在绑定 Agent 的队列里排队
  RUNNING // 已被 Agent 领取,执行中
  SUCCEEDED // 完成
  FAILED // git pull 失败 / 命令非零退出 / 产物缺失
  CANCELED // 管理员手动取消
}

// 任务触发方式:AUTO 是 cron 自动派,MANUAL 是管理员手动 trigger
enum CrawlerTaskTrigger {
  AUTO
  MANUAL
}

// 爬虫 Job 仓库类型(Jenkins 风格:每次执行先拉代码)
enum CrawlerRepoType {
  GIT
  SVN
}

// Job 参数类型,前端按此渲染表单控件
enum CrawlerJobParamType {
  DATE // 日期(DatePickerField)
  STRING // 文本(Input)
  NUMBER // 数值(Input type=number)
  ENUM // 枚举,从 options 选(Select)
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String?  @unique // 可选,创作者注册时必填;管理员 seed 可不填
  passwordHash String
  role         Role     @default(CREATOR)
  status       String   @default("pending") // pending(待运营审核) / active / disabled
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  creator      Creator?
  inspirations Inspiration[] // 创建的创作灵感(运营/管理员)

  // 阶段4 · 爬虫体系反向关系
  createdAgents   CrawlerAgent[] @relation("createdAgents")
  createdJobs     CrawlerJob[]   @relation("createdJobs")
  createdTasks    CrawlerTask[]  @relation("createdTasks")
  createdCsvTypes CsvType[]      @relation("createdCsvTypes")

  // 阶段5 · 激励人工调整记录
  adjustedIncentives Incentive[] @relation("adjustedIncentives")

  // 审计:作为操作人留下的痕迹
  auditLogs AuditLog[]
}

/// 操作审计日志:trigger / cancel / rerun / 改模板 / 改 agent 等关键动作都落一条
/// 字段说明:
///   - actorId:操作人 user.id;NULL = 系统(cron 自动触发)
///   - actorUsername:写入时快照;原 user 被删后仍可读
///   - action:形如 "task.trigger" / "task.cancel" / "task.rerun" / "job.update" / "agent.create"
///   - targetType + targetId:被操作的资源,详情页可按此过滤历史
///   - details:富 JSON,装 paramValues / fromStatus→toStatus / 改了哪些字段
model AuditLog {
  id            String   @id @default(cuid())
  actorId       String?
  actorUsername String // 快照,删用户后仍可读
  action        String // task.trigger / task.cancel / ...
  targetType    String // task / job / agent / dataset
  targetId      String?
  details       Json?
  createdAt     DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

model Creator {
  id        String  @id @default(cuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  nickname  String
  avatarUrl String? // 头像 URL
  tier      String? // 分级
  groupNo   String? // 团号(组织内部编号)

  // 外部平台账号(显式列出常用平台,Json platforms 留作扩展位)
  ysId      String? // 易闪 ID
  dyUid     String? // 抖音 UID
  dyName    String? // 抖音昵称
  dyAccount String? // 抖音号
  dyUrl     String? // 抖音主页链接

  platforms Json? // 其他平台账号(扩展)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions     Submission[]
  enrollments     ActivityEnrollment[]
  videoStats      VideoStat[] // 阶段4 · 抖音视频明细按 dyUid 匹配
  dailyVideoStats DailyVideoStat[] // 阶段4.3 · 当日快照
  incentives      Incentive[] // 阶段5 · 各活动激励快照
}

model Activity {
  id          String         @id @default(cuid())
  name        String
  description String?
  coverImage  String? // 封面图 URL,空时前端用渐变占位
  status      ActivityStatus @default(DRAFT)
  startAt     DateTime
  endAt       DateTime
  publishAt   DateTime? // 草稿定时发布;到点后由 maybeAutoPublish(读时懒执行)推到 ONGOING
  rewardRules Json           @default("{}") // 组合规则配置,阶段5引擎读取
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  submissions Submission[]
  enrollments ActivityEnrollment[]
  incentives  Incentive[] // 阶段5 · 本活动的所有激励记录

  @@index([status, startAt])
  @@index([status, publishAt])
}

model ActivityEnrollment {
  id         String   @id @default(cuid())
  creatorId  String
  activityId String
  createdAt  DateTime @default(now())

  creator  Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([creatorId, activityId])
  @@index([activityId])
}

model Submission {
  id         String  @id @default(cuid())
  creatorId  String
  activityId String?
  title      String
  url        String
  platform   String
  externalId String? // 平台稿件 ID(从 url 解析,易闪导入按 platform+externalId 匹配)

  // 最终态:由三子状态派生,持久化便于索引/列表筛选
  status     SubmissionStatus @default(PENDING)
  reviewNote String?

  // 三子审核状态(全部 APPROVED → 最终 APPROVED;任一 REJECTED → 最终 REJECTED;否则 PENDING)
  titleStatus   ReviewStatus @default(PENDING) // 视频标题
  titleNote     String?
  contentStatus ReviewStatus @default(PENDING) // 视频内容
  contentNote   String?
  yishanStatus  ReviewStatus @default(PENDING) // 易闪(导入)
  yishanNote    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator  Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  activity Activity? @relation(fields: [activityId], references: [id], onDelete: SetNull)

  @@unique([platform, externalId])
  @@index([creatorId, createdAt])
  @@index([activityId, status])
}

// 创作灵感:运营/管理员维护,创作者只读浏览。
// 三大类(视频教程/文档教程/创作素材),素材再分子类。
// content / url / coverImage 按 type+category 取舍由 zod 在入参层强校验。
model Inspiration {
  id          String            @id @default(cuid())
  type        InspirationType
  category    MaterialCategory? // 仅 type=MATERIAL 时使用
  title       String
  summary     String? // 列表短描述
  content     String? // 详细正文(文档教程 / 文本素材)
  url         String? // 视频教程 / 视频素材 / 图片素材 的资源链接
  coverImage  String? // 封面图(可选)
  tags        String[] // 标签(AI创作 / 实拍指引 / 图文创作 …)
  published   Boolean           @default(true) // 是否对创作者可见(草稿 = false)
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([type, published, createdAt])
  @@index([type, category, published])
}

// 爬虫机:管理员创建,token 以 `<agentId>.<secret>` 形式发给 agent,服务端只存 secret 段 argon2 哈希。
// 一台 Agent 可绑定多个 Job,但并发=1(串行执行队列);离线判定走 lastSeenAt(>10min 视为离线)。
model CrawlerAgent {
  id          String             @id @default(cuid())
  name        String             @unique // 机器名 / 标识(管理员设置)
  tokenHash   String // <secret> 段的 argon2 哈希
  status      CrawlerAgentStatus @default(ACTIVE)
  lastSeenAt  DateTime? // 最近一次成功鉴权时间;离线判定依据
  lastSeenIp  String?
  createdById String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  createdBy User          @relation("createdAgents", fields: [createdById], references: [id], onDelete: Restrict)
  jobs      CrawlerJob[] // 绑定到本机的 Job
  tasks     CrawlerTask[] // 派给本机执行的 Task

  @@index([status])
}

// 爬虫 Job(模板):管理员维护,定义一次"任务怎么跑"——绑哪台机、拉哪个仓库、跑什么命令、参数表单、产物清单、可选 cron。
// 每次"执行"是一条 CrawlerTask;Jenkins 风格的 Job/Build 两层。
model CrawlerJob {
  id             String          @id @default(cuid())
  name           String          @unique
  description    String?
  agentId        String // 绑定的爬虫机,N:1
  repoType       CrawlerRepoType
  repoUrl        String // git/svn 仓库地址
  repoBranch     String? // git 用,svn 忽略
  workdir        String          @default(".") // 命令工作目录(仓库根的相对路径)
  command        String // 命令模板,内含 {{paramName}} 占位符
  timeoutMinutes Int             @default(30) // 单次执行超时(到点 agent kill)
  paramSchema    Json            @default("[]") // [{name, type, required, default?, options?[]}]
  outputs        Json            @default("[]") // [{path, csvType?}] 仅带 csvType 的产物会上传中台入库
  cronExpression String? // 5 段标准 cron;null = 仅手动
  enabled        Boolean         @default(true) // 仅控 cron 自动触发开关(定时开/关)
  active         Boolean         @default(true) // 任务整体启用/停用;停用 = 不可触发(含手动),与 enabled 分离
  createdById    String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  agent     CrawlerAgent  @relation(fields: [agentId], references: [id], onDelete: Restrict)
  createdBy User          @relation("createdJobs", fields: [createdById], references: [id], onDelete: Restrict)
  tasks     CrawlerTask[]

  @@index([agentId, enabled])
  @@index([enabled, cronExpression]) // cron scheduler 扫描用
}

// 爬虫任务(一次执行):来源 = 手动 trigger 或 cron 自动建。
// jobId / agentId / sequenceNumber / paramValues 在新模型下均必填,但历史数据(改造前)允许 null。
model CrawlerTask {
  id             String             @id @default(cuid())
  jobId          String? // 关联 Job;历史任务为 null
  agentId        String? // 冗余 job.agentId 加速队列查询;历史任务可能 null
  sequenceNumber Int? // Job 内第 N 次执行(展示用 #42);历史任务 null
  paramValues    Json               @default("{}") // 本次执行的参数实际值
  trigger        CrawlerTaskTrigger
  priority       Int                @default(0) // 大的优先
  status         CrawlerTaskStatus  @default(PENDING)
  startedAt      DateTime? // Agent /claim 时设
  finishedAt     DateTime?
  errorMessage   String?
  exitCode       Int? // 命令子进程退出码
  logPath        String? // 日志文件路径,默认 data/logs/<id>.log
  createdById    String? // AUTO 任务为 null
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  job       CrawlerJob?   @relation(fields: [jobId], references: [id], onDelete: SetNull)
  agent     CrawlerAgent? @relation(fields: [agentId], references: [id], onDelete: SetNull)
  createdBy User?         @relation("createdTasks", fields: [createdById], references: [id], onDelete: SetNull)
  datasets  RawDataset[] // 1:N 一个 Task 可上传多份带 csvType 的 CSV

  @@index([status, priority, createdAt])
  @@index([agentId, status, priority, createdAt]) // agent 队列查询主索引
  @@index([jobId, sequenceNumber])
}

// 原始 CSV 数据集:agent 上传后落盘到 data/raw/<csvType>/<id>.csv,DB 只存元信息。
// 不入 public/,运营要下载得走鉴权 API。改造后一个 Task 可有多份 RawDataset(对应 Job.outputs 中带 csvType 的产物)。
model RawDataset {
  id           String    @id @default(cuid())
  csvType      String? // 入库类别;null = 仅留底下载,不入解析层
  taskId       String? // 来源 Task,可空兼容历史 / 手动导入数据
  fileName     String? // agent 报上来的原始文件名
  fileSize     Int // 字节
  contentHash  String // sha256 hex,审计 / 防重
  storagePath  String // 项目相对路径(OSS 上线后换成 OSS key)
  rowCount     Int? // 4.2 解析时填
  parsedAt     DateTime?
  parseError   String?
  uploadedById String? // CrawlerAgent.id 冗余
  createdAt    DateTime  @default(now())

  task            CrawlerTask?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  videoStats      VideoStat[] // 最近一次更新该 VideoStat 的数据集
  dailyVideoStats DailyVideoStat[] // 本次写入的当日快照
  anchorStats     AnchorStat[] // 最近一次更新该 AnchorStat 的数据集
  liveStats       LiveStat[] // 最近一次更新该 LiveStat 的数据集

  @@index([csvType, createdAt])
  @@index([taskId])
}

/// csvType 元数据(取代以前硬编码在 lib/validation/crawler.ts 和 lib/parsers/columns.ts 的 KNOWN_CSV_TYPES)。
/// columns 是 [{ name, label?, type }] 数组(JSON);type 用于 UI 推断可用 filter 操作符。
/// 添加新 csvType 时:UI 建一行(可上传 CSV/Excel 自动抽列)→ 入库即可;
/// 若想做 parser 入解析层,仍要在 lib/parsers/ 里写一个 Parser 并挂进 PARSERS 表(代码侧)。
model CsvType {
  id          String   @id @default(cuid())
  name        String   @unique // 程序 key,如 "douyin_video_detail"
  label       String // 显示名,如 "抖音视频明细表"
  description String?
  columns     Json // [{ name, label?, type: "string"|"number"|"date"|"url" }]
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User? @relation("createdCsvTypes", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([name])
}

// 明细层:抖音视频维度,按 (platform, externalId) upsert,只保留最新快照。
// csvType=douyin_video_detail 的 parser 负责写。后续阶段 6 用历史快照做每日趋势。
model VideoStat {
  id         String @id @default(cuid())
  platform   String // "douyin"
  externalId String // 平台稿件 id(从 url 解析)

  url         String
  title       String
  publishedAt DateTime?

  // CSV 自带的创作者三元组(未必都能匹配到系统 Creator)
  creatorUid     String?
  creatorName    String?
  creatorAccount String?
  creatorId      String? // 解析时按 dyUid 匹配系统 Creator,匹不到为 null

  views            Int @default(0)
  recommendedViews Int @default(0)
  likes            Int @default(0)
  comments         Int @default(0)
  shares           Int @default(0)
  fansGained       Int @default(0)

  operatorAgent String? // 运营经纪人
  recruitAgent  String? // 招募经纪人
  note          String? // CSV 备注列

  lastDatasetId String? // 最近一次写本行的 RawDataset(审计)

  // 达人删除/隐藏标记:每次导入(手动 / 爬虫)按 externalId 全表比对,
  // 在库但本次导入缺失 → hidden=true;重新出现 → 改回 false。
  // 约定:本表只承载单个游戏的数据,故用「全表比对」;hidden 行不参与任何统计/计算,
  // 仅留存并在视频数据表格中展示(附筛选)。
  hidden   Boolean   @default(false)
  hiddenAt DateTime? // 首次判定为删除/隐藏的时间(重新出现则清空)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator     Creator?         @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  lastDataset RawDataset?      @relation(fields: [lastDatasetId], references: [id], onDelete: SetNull)
  dailyStats  DailyVideoStat[]

  @@unique([platform, externalId])
  @@index([creatorId, updatedAt])
  @@index([creatorUid])
  @@index([publishedAt])
  @@index([platform, hidden])
}

// 每日汇总层:Detail 写入后立刻按"北京时间今日"upsert 一份当日快照。
// 同一天多次上传 CSV 时,后者覆盖前者(snapshot=当日最新累计值)。
// (TODO 阶段6 cron:若某日完全没有 CSV 上传,该日就没有快照,留洞由 cron 补)
model DailyVideoStat {
  id           String   @id @default(cuid())
  platform     String
  externalId   String
  snapshotDate DateTime @db.Date // 仅日期部分,代表"北京时间这一天"

  views            Int
  recommendedViews Int
  likes            Int
  comments         Int
  shares           Int
  fansGained       Int

  // 关联(全部可空 / SetNull,删源不会级联删快照)
  creatorId   String?
  videoStatId String?
  datasetId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator   Creator?    @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  videoStat VideoStat?  @relation(fields: [videoStatId], references: [id], onDelete: SetNull)
  dataset   RawDataset? @relation(fields: [datasetId], references: [id], onDelete: SetNull)

  @@unique([platform, externalId, snapshotDate])
  @@index([snapshotDate])
  @@index([creatorId, snapshotDate])
  @@index([videoStatId, snapshotDate])
}

// 主播数据明细层:按 platform+uid 唯一,导入(手动 / 爬虫)覆盖只留最新。
// 与 VideoStat 同构:承载单个游戏的主播明细,可挂 lastDatasetId 审计来源。
// 数值口径:计数类用 Int;可能为小数的(ACU / 直播时长 / 人均观看时长)用 Float。
model AnchorStat {
  id       String  @id @default(cuid())
  platform String // 主播平台,如 "douyin"
  uid      String // 平台 UID
  nickname String? // 主播昵称
  account  String? // 抖音号

  joinedAt      DateTime? // 入会时间
  groupNo       String? // 团号
  operatorAgent String? // 运营经纪人
  recruitAgent  String? // 招募经纪人

  fans                  Int   @default(0) // 粉丝量
  worksCount            Int   @default(0) // 作品数
  worksViews            Int   @default(0) // 作品播放量
  worksRecommendedViews Int   @default(0) // 作品推荐播放量
  anchorDays            Int   @default(0) // 直播天数(=开播天数)
  acu                   Float @default(0) // ACU(平均同时在线)
  liveDuration          Float @default(0) // 直播时长
  liveSessions          Int   @default(0) // 直播场次
  exposureUsers         Int   @default(0) // 曝光人数
  exposureCount         Int   @default(0) // 曝光次数
  enterRoomUsers        Int   @default(0) // 进直播间人数
  enterRoomCount        Int   @default(0) // 进直播间次数
  avgWatchDuration      Float @default(0) // 人均观看时长

  lastDatasetId String? // 最近一次写本行的 RawDataset(审计)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lastDataset RawDataset? @relation(fields: [lastDatasetId], references: [id], onDelete: SetNull)

  @@unique([platform, uid])
  @@index([groupNo])
  @@index([updatedAt])
}

// 直播明细层:脚本产出的「所有主播画像表」——按 主播 × 自然日 一行。
// 导入(手动 / 爬虫)按 (platform, uid, date) upsert 只留最新。
// 约定:只入库「有效开播时长 > 0」的条目(没开播的空行不入);排除游戏流水/主播收入两列。
// 数值口径:计数类用 Int;可能为小数的(开播时长 / 转化率 / 人均观看时长 / ACU)用 Float。
model LiveStat {
  id       String   @id @default(cuid())
  platform String // 主播平台,如 "douyin"
  uid      String // 平台 UID(取 UID2 列去前缀,避免 Excel 科学计数法丢精度)
  date     DateTime @db.Date // 日期(自然日)
  nickname String? // 主播名称
  account  String? // 主播账号(抖音号)

  soundWave        Int   @default(0) // 音浪(火力)
  liveDuration     Float @default(0) // 有效开播时长(小时)
  exposureUsers    Int   @default(0) // 曝光人数
  exposureCount    Int   @default(0) // 曝光次数
  enterRoomUsers   Int   @default(0) // 进直播间人数
  enterRoomCount   Int   @default(0) // 进直播间次数
  enterRoomRate    Float @default(0) // 进直播间转化率(%)
  avgWatchDuration Float @default(0) // 人均观看时长(分钟)
  tipUsers         Int   @default(0) // 打赏人数
  tipCount         Int   @default(0) // 打赏次数
  newFans          Int   @default(0) // 新增粉丝
  acu              Float @default(0) // ACU(平均同时在线)

  operatorAgent String? // 运营经纪人
  recruitAgent  String? // 招募经纪人
  note          String? // 备注(团号)

  lastDatasetId String? // 最近一次写本行的 RawDataset(审计)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lastDataset RawDataset? @relation(fields: [lastDatasetId], references: [id], onDelete: SetNull)

  @@unique([platform, uid, date])
  @@index([uid, date])
  @@index([date])
  @@index([note])
}

// 阶段5 · 激励 / 结算快照。
// 每个 (creatorId, activityId) 一行;运营点"计算预估"时 upsert(重跑覆盖 estimated/breakdown/computedAt)。
// adjusted 是人工调整后的最终值;有值则结算以它为准,审计写在 AuditLog(action="incentive.adjust")。
// breakdown 落引擎 IncentiveContribution[] JSON,前端展开看"每条规则贡献多少"。
model Incentive {
  id           String    @id @default(cuid())
  creatorId    String
  activityId   String
  estimated    Decimal   @db.Decimal(12, 2) // 引擎最新一次计算结果
  adjusted     Decimal?  @db.Decimal(12, 2) // 人工调整后的金额;null = 沿用 estimated
  adjustedById String? // 调整操作人;null = 未调整
  adjustedAt   DateTime?
  adjustReason String? // 调整原因(便于审计 / 创作者沟通)
  breakdown    Json      @default("[]") // IncentiveContribution[] 快照
  computedAt   DateTime  @default(now()) // 最近一次跑引擎时间
  status       String    @default("estimated") // estimated / settled(阶段5 只做 estimated,settled 留位)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  creator    Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  activity   Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  adjustedBy User?    @relation("adjustedIncentives", fields: [adjustedById], references: [id], onDelete: SetNull)

  @@unique([creatorId, activityId])
  @@index([activityId])
  @@index([creatorId, status])
}

/// 阶段9 · 舆情监控 LLM 全局配置(单例:id 恒等 1)。
/// apiKeyEnc 为 AES-256-GCM 密文(格式见 lib/crypto.ts),明文只在触发生成时临时解出往分析服务传;
/// apiKeyMask 是打码后的显示串(如 "sk-****abcd"),用于 UI 回显,不含真实密钥。
/// provider = "echo" 时代表离线规则模式,apiKey 仍必填但不会被 slg_analyzer 使用。
model OpinionSettings {
  id         Int      @id @default(1) // 单例锁:业务代码只写 id=1
  provider   String // "anthropic" | "openai" | "echo"
  model      String // 如 "claude-sonnet-4-5" / "gpt-4o" / "echo"
  apiKeyEnc  String   @default("") // AES-256-GCM 密文的 base64;初始为空表示"未配置"
  apiKeyMask String   @default("") // 打码后的展示串
  baseUrl    String? // OpenAI 兼容端点(如 https://api.deepseek.com/v1)
  updatedBy  String? // username 快照;seed 时为 "<system>"
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@map("opinion_settings")
}

/// 阶段10 · AI 助手 · 模型配置(按用途单例:usage 唯一,如 chat / embedding)。
/// 泛化自 OpinionSettings:apiKeyEnc = AES-256-GCM 密文,明文只在服务端解出调模型,永不回前端/入日志。
/// baseUrl 指向国产模型的 OpenAI 兼容端点(数据不出境)。
model AiModelProfile {
  id         String   @id @default(cuid())
  usage      String   @unique // "chat" | "embedding"
  provider   String // "bailian" | "mimo" | "deepseek" ...
  model      String // "qwen-max" 等
  baseUrl    String // OpenAI 兼容端点
  apiKeyEnc  String   @default("") // 密文,空 = 未配置
  apiKeyMask String   @default("") // 打码回显串
  updatedBy  String?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@map("ai_model_profile")
}

/// 阶段10 · AI 助手 · 会话(运营 × 一组多轮对话)。
model AiConversation {
  id        String   @id @default(cuid())
  userId    String // User.id 快照(不建外键,删用户不级联删对话历史)
  title     String?
  status    String   @default("active") // active / archived
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages AiMessage[]
  runs     AiRun[]

  @@index([userId, updatedAt])
  @@map("ai_conversation")
}

/// 阶段10 · AI 助手 · 消息。content 存文本 + 引用 + 工具结果摘要(已脱敏)。
model AiMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String // user / assistant / tool
  content        Json
  createdAt      DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("ai_message")
}

/// 阶段10 · AI 助手 · 一次执行(模型 / token / 耗时 / 状态)。工具轨迹见 AiToolCall(阶段10.2 再加)。
model AiRun {
  id             String    @id @default(cuid())
  conversationId String
  model          String
  promptVersion  Int?
  status         String    @default("running") // running / succeeded / failed
  inputTokens    Int?
  outputTokens   Int?
  latencyMs      Int?
  errorMessage   String?
  createdAt      DateTime  @default(now())
  finishedAt     DateTime?

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toolCalls    AiToolCall[]

  @@index([conversationId, createdAt])
  @@map("ai_run")
}

/// 阶段10.2 · AI 助手 · 一次工具调用轨迹(工具名 / 入参 / 结果摘要)。
model AiToolCall {
  id            String   @id @default(cuid())
  runId         String
  toolName      String
  args          Json
  resultSummary Json? // 脱敏/裁剪后的结果(工具返回已是有限行的业务聚合)
  latencyMs     Int?
  isError       Boolean  @default(false)
  createdAt     DateTime @default(now())

  run AiRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@map("ai_tool_call")
}

/// 阶段10 · AI 助手 · 系统提示词版本(可回溯每条回答用了哪版 prompt)。
model AiPromptVersion {
  id        String   @id @default(cuid())
  name      String // "operator_assistant"
  version   Int
  content   String
  active    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([name, version])
  @@map("ai_prompt_version")
}
