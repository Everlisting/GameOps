# 数据库
DATABASE_URL="postgresql://user:password@localhost:5432/gameops?schema=public"

# 会话 JWT 密钥(至少 32 字符,生产用强随机值)
AUTH_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"

# 应用地址
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 飞书群机器人 webhook(阶段6启用,先留空占位)
FEISHU_WEBHOOK_URL=""

# 抖音 Open Platform access_token(可选)
# 留空时审核弹窗会先尝试无 token 调 get_iframe_by_video,失败则回退到
# open.douyin.com/player/video?vid=...&autoplay=1 拼接的兜底 URL。
DOUYIN_ACCESS_TOKEN=""

NODE_ENV="development"

# ── 阶段9 · 舆情监控 ─────────────────────────────────────────────
# 分析服务 (Docker 容器) 地址,本地开发默认 http://127.0.0.1:8000
ANALYSIS_BASE_URL="http://127.0.0.1:8000"
# 与分析服务共享的 Bearer 密钥(生成:node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ANALYSIS_SHARED_SECRET=""
# LLM apiKey 主密钥(32 字节 base64;生成:node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
OPINION_AES_KEY=""
