# 复制为 .env(同目录),把值改成自己的。
# .env 已在 .gitignore;不要把真实 token 提交到仓库。

# 中台地址(生产强烈建议 https)
CRAWLER_BASE_URL=https://gameops.example.com

# 创建 agent 时一次性返回的 token,形如 <agentId>.<secret>
CRAWLER_TOKEN=ckxxxxxxxxxxxx.AbCdEfGhIjKlMnOpQrStUvWxYzABC

# 可选:Agent 工作目录(每个 Job 在下面建 job-<jobId>/ 子目录)
# 不填默认 ./workspaces
# CRAWLER_WORK_ROOT=D:\crawler\workspaces

# 可选:本地日志目录(heartbeat.log / executor.log)
# 不填默认 ./logs
# CRAWLER_LOG_DIR=D:\crawler\logs
